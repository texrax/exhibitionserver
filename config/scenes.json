{
  "start": {
    "description": "展間開始 — 重置狀態、關燈、播影片、切VTuber、亮左壁燈",
    "actions": [
      { "device": "yolo_detector", "action": "stop", "params": {} },
      { "device": "vtubestudio", "action": "removeAllExpressions", "params": { "fadeTime": 0.3 } },
      { "device": "vtubestudio", "action": "triggerHotkey", "params": { "name": "待機" } },
      { "device": "wizlight_all", "action": "off", "params": {} },
      { "device": "esp32_main", "action": "off", "params": {} },
      { "delay": 500 },
      { "device": "obs", "action": "switchScene", "params": { "sceneName": "Video" } },
      { "device": "obs", "action": "triggerMediaInput", "params": { "inputName": "Media", "mediaAction": "OBS_WEBSOCKET_MEDIA_INPUT_ACTION_RESTART" } },
      { "waitForEvent": "obs:mediaEnded", "timeout": 300000 },
      { "device": "obs", "action": "switchScene", "params": { "sceneName": "VTuber" } },
      { "device": "bulb_1", "action": "setTemp", "params": { "temp": 4000, "brightness": 100 } }
    ]
  },

  "right_lights_white": {
    "description": "右聚光燈和右壁燈亮白燈",
    "actions": [
      { "device": "wizlight_right", "action": "setTemp", "params": { "temp": 4000, "brightness": 100 } }
    ]
  },

  "scene_2": {
    "description": "情境二 — 右聚光燈和右壁燈亮琥珀色",
    "actions": [
      { "device": "wizlight_right", "action": "setColor", "params": { "r": 255, "g": 160, "b": 20, "brightness": 100 } }
    ]
  },

  "play_day_1": {
    "description": "星期一 — 冷紫閃爍 + 數位焦慮",
    "actions": [
      { "device": "vtubestudio", "action": "moveModel", "params": { "timeInSeconds": 0.4, "size": 10, "positionY": 0.05, "relative": true } },
      { "device": "vtubestudio", "action": "setExpression", "params": { "file": "哀傷.exp3.json", "active": true, "fadeTime": 0.3 } },
      { "device": "audio", "action": "play", "params": { "file": "開齋節.wav" } },
      { "device": "bulb_1", "action": "flickerEffect", "params": { "r": 130, "g": 10, "b": 220, "min": 30, "max": 70 } },
      { "device": "esp32_main", "action": "setMode", "params": { "mode": "blink" } },
      { "delay": 6000 },
      { "device": "vtubestudio", "action": "removeAllExpressions", "params": { "fadeTime": 0.5 } },
      { "device": "vtubestudio", "action": "moveModel", "params": { "timeInSeconds": 0.4, "size": -10, "positionY": -0.05, "relative": true } },
      { "device": "bulb_1", "action": "stopEffect", "params": {} },
      { "device": "bulb_1", "action": "off", "params": {} },
      { "device": "esp32_main", "action": "setMode", "params": { "mode": "standby" } }
    ]
  },


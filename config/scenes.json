      { "device": "wizlight_all", "action": "stopEffect", "params": {} },
      { "device": "wizlight_all", "action": "off", "params": {} },
      { "device": "esp32_main", "action": "off", "params": {} },
      { "device": "audio", "action": "stop", "params": {} },

  "yolo_deliver_vegetable": {
    "description": "YOLO 青菜 — 琥珀燈光 + 吃青菜動畫",
    "trigger": { "event": "yolo_detector:deliver", "condition": { "food": "vegetables" } },
    "actions": [
      { "device": "esp32_main", "action": "setMode", "params": { "mode": "block_wave" } },
      { "device": "vtubestudio", "action": "triggerHotkey", "params": { "name": "吃飯手開關" } },
      { "device": "vtubestudio", "action": "triggerHotkey", "params": { "name": "吃青菜" } },
      { "delay": 5000 },
      { "device": "esp32_main", "action": "setMode", "params": { "mode": "standby" } }
    ]
  },

  "yolo_deliver_beef": {
    "description": "YOLO 牛肉 — 琥珀燈光 + 吃丸子動畫",
    "trigger": { "event": "yolo_detector:deliver", "condition": { "food": "beef" } },
    "actions": [
      { "device": "esp32_main", "action": "setMode", "params": { "mode": "block_wave" } },
      { "device": "vtubestudio", "action": "triggerHotkey", "params": { "name": "吃飯手開關" } },
      { "device": "vtubestudio", "action": "triggerHotkey", "params": { "name": "吃丸子" } },
      { "delay": 5000 },
      { "device": "esp32_main", "action": "setMode", "params": { "mode": "standby" } }
    ]
  },

  "all_off": {
    "description": "全部關閉",
    "actions": [
      { "device": "esp32_main", "action": "off", "params": {} },
      { "device": "audio", "action": "stop", "params": {} },
      { "device": "vtubestudio", "action": "removeAllExpressions", "params": { "fadeTime": 0.5 } }
    ]
  }

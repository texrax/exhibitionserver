  "after_day_selection": {
    "description": "選到正確日子(星期三) — VTuber 換衣服拿碗筷，進入餐桌互動",
    "trigger": { "event": "visitor:day_completed", "condition": { "day": 3 } },
    "exclusive": false,
    "actions": [
      { "device": "vtubestudio", "action": "removeAllExpressions", "params": { "fadeTime": 0.3 } },
      { "device": "vtubestudio", "action": "triggerHotkey", "params": { "name": "更換衣服" } },
      { "device": "vtubestudio", "action": "triggerHotkey", "params": { "name": "吃飯手開關" } },
      { "device": "spotlight_1", "action": "off", "params": {} },
      { "device": "bulb_1", "action": "off", "params": {} },
      { "device": "bulb_3", "action": "off", "params": {} },
      { "device": "esp32_main", "action": "off", "params": {} },
      { "device": "bulb_2", "action": "setTemp", "params": { "temp": 4000, "brightness": 100 } },
      { "device": "spotlight_2", "action": "on", "params": {} },
      { "device": "yolo_detector", "action": "start", "params": {} }
    ]
  },

  "yolo_deliver_vegetable": {
    "description": "YOLO 青菜 — 琥珀燈光 + 吃青菜動畫",
    "trigger": { "event": "yolo_detector:deliver", "condition": { "food": "vegetables" } },
    "actions": [
      { "device": "esp32_main", "action": "setMode", "params": { "mode": "block_wave" } },
      { "device": "vtubestudio", "action": "triggerHotkey", "params": { "name": "吃飯手開關" } },
      { "device": "vtubestudio", "action": "triggerHotkey", "params": { "name": "吃青菜" } },
      { "delay": 5000 },
      { "device": "esp32_main", "action": "setMode", "params": { "mode": "standby" } }
    ]
  },

  "yolo_deliver_beef": {
    "description": "YOLO 牛肉 — 琥珀燈光 + 吃丸子動畫",
    "trigger": { "event": "yolo_detector:deliver", "condition": { "food": "beef" } },
    "actions": [
      { "device": "esp32_main", "action": "setMode", "params": { "mode": "block_wave" } },
      { "device": "vtubestudio", "action": "triggerHotkey", "params": { "name": "吃飯手開關" } },

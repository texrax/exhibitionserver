{
  "devices": [
    {
      "id": "vtubestudio",
      "type": "VTubeStudioDevice",
      "config": {
        "host": "localhost",
        "port": 8001,
        "pluginName": "ExhibitionServer",
        "pluginDeveloper": "Exhibition",
        "tokenPath": "./config/vts_token.txt",
        "zoomOnExpression": false
      }
    },
    {
      "id": "esp32_main",
      "type": "ESP32Device",
      "config": {
        "ip": "192.168.31.101",
        "timeout": 3000,
        "throttleMs": 150
      }
    },
    {
      "id": "audio",
      "type": "AudioPlayerDevice",
      "config": {
        "audioDir": "./public/audio"
      }
    },
    {
      "id": "camera",
      "type": "CameraSensorDevice",
      "config": {
        "script": "./camera.py",
        "triggerThreshold": 0.8
      }
    },
    {
      "id": "obs",
      "type": "OBSDevice",
      "config": {
        "host": "localhost",
        "port": 4455,
        "password": "00000000"
      }
    },
    {
      "id": "yolo_detector",
      "type": "YoloDetectorDevice",
      "config": {
        "projectPath": "./yolo",
        "pythonPath": "py",
        "env": {
          "YOLO_PROFILE": "y11",
          "CAMERA_SOURCE": "0",
          "CHOPSTICKS_MODEL_Y11": "../models/chopsticks.pt",
          "FOOD_MODEL_Y11": "../models/food.pt",
          "BOWL_MODEL_Y11": "",
          "CAMERA_CROP": "0.05,0.0,0.65,1.0",
          "DETECT_EVERY_N": "5",
          "CHOPSTICKS_CONF": "0.08",
          "CHOPSTICKS_MIN_ASPECT": "2.0",
          "FOOD_CONF": "0.50",
          "FOOD_MAX_DET": "6",
          "LEFT_BOWL_ZONE": "0.05,0.05,0.40,0.40",
          "RIGHT_BOWL_ZONE": "0.40,0.05,0.75,0.40"
        },
        "url": "http://localhost:8000",
        "pollIntervalMs": 500,
        "cooldownMs": 3000,
        "startupTimeoutMs": 30000
      }
    }
  ]
}
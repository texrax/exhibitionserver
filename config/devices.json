{
  "devices": [
    {
      "id": "vtubestudio",
      "type": "VTubeStudioDevice",
      "config": {
        "host": "localhost",
        "port": 8001,
        "pluginName": "ExhibitionServer",
        "pluginDeveloper": "Exhibition",
        "tokenPath": "./config/vts_token.txt"
      }
    },
    {
      "id": "esp32_main",
      "type": "ESP32Device",
      "config": {
        "ip": "172.20.10.2", 
        "timeout": 5000,
        "throttleMs": 200
      }
    },
    {
      "id": "audio",
      "type": "AudioPlayerDevice",
      "config": {
        "audioDir": "./public/audio"
      }
    },
    {
      "id": "camera",
      "type": "CameraSensorDevice",
      "config": {
        "script": "./camera.py",
        "triggerThreshold": 0.8
      }
    },
    {
      "id": "yolo_detector",
      "type": "YoloDetectorDevice",
      "config": {
        "url": "http://localhost:8000",
        "pollIntervalMs": 500,
        "cooldownMs": 3000,
        "timeout": 3000
      }
    },
    {
      "id": "wizlight",
      "type": "WizLightDevice",
      "config": {
        "ip": "192.168.0.127",
        "port": 38899,
        "timeout": 2000
      }
    }
  ]
}
{
  "devices": [
    {
      "id": "vtubestudio",
      "type": "VTubeStudioDevice",
      "config": {
        "host": "localhost",
        "port": 8001,
        "pluginName": "ExhibitionServer",
        "pluginDeveloper": "Exhibition",
        "tokenPath": "./config/vts_token.txt",
        "zoomOnExpression": false
      }
    },
    {
      "id": "esp32_main",
      "type": "ESP32Device",
      "config": {
        "ip": "192.168.31.101",
        "timeout": 3000,
        "throttleMs": 150
      }
    },
    {
      "id": "audio",
      "type": "AudioPlayerDevice",
      "config": {
        "audioDir": "./public/audio"
      }
    },
    {
      "id": "camera",
      "type": "CameraSensorDevice",
      "config": {
        "script": "./camera.py",
        "triggerThreshold": 0.8
      }
    },
    {
      "id": "yolo_detector",
      "type": "YoloDetectorDevice",
      "config": {
        "projectPath": "./yolo",
        "env": {
          "YOLO_PROFILE": "y11",
          "CAMERA_SOURCE": "1",
          "CHOPSTICKS_MODEL_Y11": "models/chopsticks.pt",
          "FOOD_MODEL_Y11": "models/food.pt",
          "BOWL_MODEL_Y11": "",
          "LEFT_BOWL_ZONE": "0.08,0.52,0.42,0.95",
          "RIGHT_BOWL_ZONE": "0.58,0.52,0.92,0.95"
        },
        "url": "http://localhost:8000",
        "pollIntervalMs": 500,
        "cooldownMs": 3000,
        "startupTimeoutMs": 15000
      }
    }
  ]
}